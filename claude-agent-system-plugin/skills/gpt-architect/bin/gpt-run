#!/bin/bash
# gpt-run вЂ” one GPT-5.6 worker via `codex exec`, built for PARALLEL fan-out from Claude Code.
#
# WHY: the codex MCP tools serialize inside Claude Code even when batched in one message
# (verified 2026-07-12: worker B's session started 183ms AFTER worker A's last event).
# This wrapper is the parallel lane: launch N of these as background Bash tasks and they
# genuinely run concurrently, each writing its own rollout (gpt-watch sees them all).
#
# Usage:
#   gpt-run [-m sol|terra|luna] [-e low|medium|high|xhigh|max|ultra] [-s ro|ws|full]
#           [-C <cwd>] [-n <name>] [-r <threadId>] [promptfile]
#
# Prompt comes from <promptfile> or stdin (heredoc). Blocks until the worker finishes,
# then prints the same рџ¤– summary line as the MCP telemetry hook, plus the worker's
# FINAL MESSAGE вЂ” the Bash task output is all Claude needs to read.
# Artifacts: ~/.claude/gpt-runs/<ts>-<name>/{prompt.md,final.md,log}
# -r resumes an existing session (parallel-safe codex-reply; model/sandbox inherited).

set -u
MODEL=sol EFFORT=high EFFORT_SET=0 SBX=workspace-write CWD="$PWD" NAME="" RESUME=""
while getopts "m:e:s:C:n:r:h" opt; do
  case $opt in
    m) MODEL=$OPTARG ;;
    e) EFFORT=$OPTARG; EFFORT_SET=1 ;;
    s) case $OPTARG in
         ro) SBX=read-only ;; ws) SBX=workspace-write ;; full) SBX=danger-full-access ;;
         *) SBX=$OPTARG ;;
       esac ;;
    C) CWD=$OPTARG ;;
    n) NAME=$OPTARG ;;
    r) RESUME=$OPTARG ;;
    h) sed -n '2,18p' "$0"; exit 0 ;;
    *) exit 2 ;;
  esac
done
shift $((OPTIND - 1))

[[ $MODEL == gpt-* ]] || MODEL="gpt-5.6-$MODEL"
[[ $MODEL == gpt-5.6-luna && $EFFORT == ultra ]] && EFFORT=max   # luna has no ultra

[[ -n $NAME ]] || NAME="worker-$$"
DIR="$HOME/.claude/gpt-runs/$(date +%Y%m%d-%H%M%S)-$NAME"
mkdir -p "$DIR"
PROMPT="$DIR/prompt.md" FINAL="$DIR/final.md" LOG="$DIR/log"
if [[ $# -ge 1 ]]; then cp "$1" "$PROMPT"; else cat > "$PROMPT"; fi

CODEX=${CODEX_BIN:-}
if [[ -z $CODEX ]]; then
  CODEX=$(command -v codex 2>/dev/null || true)
fi
if [[ -z $CODEX && -x /opt/homebrew/bin/codex ]]; then
  CODEX=/opt/homebrew/bin/codex
fi
if [[ -z $CODEX || ! -x $CODEX ]]; then
  echo "gpt-run: Codex CLI not found. Set CODEX_BIN or install/login with the codex CLI." >&2
  exit 127
fi
if [[ -n $RESUME ]]; then
  echo "рџљЂ в†© вЂ¦${RESUME: -6} resume В· $NAME В· $DIR"
else
  case $SBX in read-only) SBTAG=ro ;; workspace-write) SBTAG=ws ;; *) SBTAG=FULL ;; esac
  echo "рџљЂ ${MODEL#gpt-5.6-} $EFFORT $SBTAG В· $NAME В· $DIR"
fi

START=$(date +%s)
if [[ -n $RESUME ]]; then
  EXTRA=()
  [[ $EFFORT_SET == 1 ]] && EXTRA+=(-c "model_reasoning_effort=$EFFORT")
  "$CODEX" exec resume "$RESUME" --skip-git-repo-check \
    ${EXTRA+"${EXTRA[@]}"} -o "$FINAL" - < "$PROMPT" > "$LOG" 2>&1
else
  "$CODEX" exec --skip-git-repo-check -C "$CWD" -m "$MODEL" \
    -c "model_reasoning_effort=$EFFORT" --sandbox "$SBX" \
    -o "$FINAL" - < "$PROMPT" > "$LOG" 2>&1
fi
RC=$?
DUR=$(( $(date +%s) - START ))

SID=$(grep -m1 -oE 'session id: [0-9a-f-]{36}' "$LOG" | awk '{print $3}')
[[ -z ${SID:-} && -n $RESUME ]] && SID=$RESUME

# Summary line from the rollout вЂ” same single-pass/baseline logic as the MCP hook,
# so resumed sessions report only the last call's share.
python3 - "${SID:-}" "$DUR" "$RC" <<'PY'
import json, sys, glob, os, time
sid, dur, rc = sys.argv[1], int(sys.argv[2]), int(sys.argv[3])
k = lambda n: f"{n/1e6:.1f}M" if n >= 1e6 else (f"{round(n/1000)}k" if n >= 1000 else str(n))
model = eff = ""; cmds = edits = 0; tok = None; lastRL = firstRL = None
base = {"cmds": 0, "edits": 0, "tok": None, "rl": None}
files = glob.glob(os.path.expanduser(f"~/.codex/sessions/*/*/*/rollout-*-{sid}.jsonl")) if sid else []
if files:
    for line in open(files[0]):
        try: d = json.loads(line)
        except Exception: continue
        pay = d.get("payload") or {}; t = d.get("type")
        if t == "turn_context":
            model = pay.get("model") or model
            eff = pay.get("effort") or pay.get("reasoning_effort") or eff
        elif t == "response_item" and pay.get("type") in ("custom_tool_call", "function_call"):
            cmds += 1
        elif t == "event_msg":
            pt = pay.get("type")
            if pt == "task_started":
                base = {"cmds": cmds, "edits": edits, "tok": tok, "rl": lastRL}
            elif pt == "exec_command_begin": cmds += 1
            elif pt == "patch_apply_end" and pay.get("success") is not False: edits += 1
            elif pt == "token_count":
                tok = (pay.get("info") or {}).get("total_token_usage") or tok
                rl = pay.get("rate_limits")
                if rl and rl.get("primary"):
                    firstRL = firstRL or rl; lastRL = rl
ctok = ((tok or {}).get("total_tokens", 0)) - ((base["tok"] or {}).get("total_tokens", 0))
ccmds, cedits = cmds - base["cmds"], edits - base["edits"]
def quota():
    if not lastRL: return None
    now = round(lastRL["primary"]["used_percent"])
    bp = ((base["rl"] or firstRL or {}).get("primary") or {}).get("used_percent")
    dl = round(lastRL["primary"]["used_percent"] - bp) if bp is not None else 0
    r = ""
    ra = lastRL["primary"].get("resets_at")
    if ra:
        s = round(ra - time.time())
        if s > 0: r = " в†»" + (f"{s//3600}h{round(s%3600/60)}m" if s >= 3600 else f"{round(s/60)}m")
    q = "5h: " + (f"+{dl}% в†’ " if dl > 0 else "") + f"{now}%{r}"
    sec = lastRL.get("secondary")
    if sec: q += f" В· wk {round(sec['used_percent'])}%"
    return q
durs = f"{dur//60}m{dur%60}s" if dur >= 60 else f"{dur}s"
bits = [("вљ пёЏ " if rc else "") + "рџ¤– " + (model.replace("gpt-5.6-", "") or "?") + (f" {eff}" if eff else ""),
        durs, f"{k(ctok)} tok" if ctok else None, f"{ccmds} cmds" if ccmds else None,
        f"{cedits} edits" if cedits else None, quota(),
        f"вЂ¦{sid[-6:]}" if sid else None, f"rc={rc}" if rc else None]
print(" В· ".join(b for b in bits if b))
PY

[[ -n ${SID:-} ]] && echo "resume: gpt-run -r $SID   (= codex-reply threadId)"
echo "--- FINAL MESSAGE ($FINAL) ---"
if ! cat "$FINAL" 2>/dev/null; then
  echo "(no final message вЂ” last log lines:)"; tail -15 "$LOG"
fi
exit $RC
