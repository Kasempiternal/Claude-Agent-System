#!/usr/bin/env python3
"""gpt-watch — live view of GPT-5.6 Codex workers (MCP subagents + gpt: direct lane).

Tails ~/.codex/sessions/**/rollout-*.jsonl, which Codex writes in real time for every
session, and pretty-prints what each worker is doing: narration, reasoning summaries,
shell commands, file edits, token usage. Multiple concurrent workers get color-coded
short-id prefixes.

Usage:
  gpt-watch                 follow all sessions active in the last 15 min + new ones
  gpt-watch --since 60      widen the attach window to 60 min
  gpt-watch --last          replay the newest session from the start, then follow
  gpt-watch --for 8         exit after 8 seconds (cheap scripted status peek)
  gpt-watch --no-tokens     hide token-count lines
"""

import argparse, glob, json, os, sys, time

SESS = os.path.expanduser("~/.codex/sessions")
PALETTE = [36, 33, 35, 32, 34, 31]  # cyan yellow magenta green blue red
DIM, RST, BOLD = "\033[2m", "\033[0m", "\033[1m"

def c(code, s): return f"\033[{code}m{s}{RST}"

def short(sid): return (sid or "??????")[-6:]

def trunc(s, n):
    s = " ".join(str(s).split())
    return s if len(s) <= n else s[: n - 1] + "…"

class Tail:
    def __init__(self, path, replay_all):
        self.path = path
        # rollout-<timestamp>-<uuid>.jsonl — uuid is the session id
        base = os.path.basename(path)[:-len(".jsonl")]
        self.sid = "-".join(base.split("-")[-5:])
        self.color = PALETTE[hash(path) % len(PALETTE)]
        self.last_tok = 0
        self.fh = open(path, "r", errors="replace")
        size = os.path.getsize(path)
        if not replay_all and size > 512_000:
            self.fh.seek(size - 65_536)
            self.fh.readline()  # drop partial line
            print(self.prefix() + DIM + "(attached mid-session)" + RST)

    def prefix(self):
        return c(self.color, f"[{short(self.sid)}] ")

    def emit(self, line, show_tokens):
        try:
            d = json.loads(line)
        except Exception:
            return
        t, p = d.get("type"), d.get("payload") or {}
        pre = self.prefix()

        if t == "session_meta":
            self.sid = p.get("id") or p.get("session_id") or ""
            pre = self.prefix()
            print(pre + c(self.color, BOLD + "▶ worker session") + f"  cwd={p.get('cwd','?')}")
            return
        if t == "turn_context":
            model = p.get("model") or (p.get("turn_context") or {}).get("model")
            eff = p.get("effort") or p.get("reasoning_effort")
            bits = " ".join(x for x in (model, eff and f"effort={eff}") if x)
            if bits:
                print(pre + DIM + f"model: {bits}" + RST)
            return
        if t == "event_msg":
            pt = p.get("type")
            if pt == "user_message":
                print(pre + DIM + "brief: " + trunc(p.get("message", ""), 180) + RST)
            elif pt == "agent_message":
                print(pre + c(self.color, "💬 ") + trunc(p.get("message", ""), 400))
            elif pt == "exec_command_begin":
                cmd = p.get("command")
                cmd = " ".join(cmd) if isinstance(cmd, list) else str(cmd)
                print(pre + c(33, "$ ") + trunc(cmd, 200))
            elif pt == "exec_command_end":
                ec = p.get("exit_code")
                mark = c(32, "✓") if ec == 0 else c(31, f"✗ exit {ec}")
                print(pre + f"  {mark}" + DIM + f" ({p.get('duration_ms','?')}ms)" + RST)
            elif pt in ("patch_apply_begin", "patch_apply_end"):
                if pt == "patch_apply_begin":
                    files = ", ".join(list((p.get("changes") or {}).keys())[:4])
                    print(pre + c(35, "✏ editing: ") + trunc(files or "?", 200))
                else:
                    ok = p.get("success")
                    print(pre + (c(32, "✓ patch applied") if ok else c(31, "✗ patch FAILED")))
            elif pt == "token_count" and show_tokens:
                info = (p.get("info") or {}).get("total_token_usage") or {}
                tot = info.get("total_tokens", 0)
                if tot - self.last_tok >= 25_000 or self.last_tok == 0:
                    self.last_tok = tot
                    rl = p.get("rate_limits") or {}
                    pri, sec = rl.get("primary") or {}, rl.get("secondary") or {}
                    rls = ""
                    if pri.get("used_percent") is not None:
                        rls = f" · 5h {pri['used_percent']:.0f}%"
                        if sec.get("used_percent") is not None:
                            rls += f" · wk {sec['used_percent']:.0f}%"
                    print(pre + DIM + f"tokens: {info.get('input_tokens',0)//1000}k in / "
                          f"{info.get('output_tokens',0)/1000:.1f}k out "
                          f"({info.get('reasoning_output_tokens',0)/1000:.1f}k reasoning){rls}" + RST)
            elif pt in ("turn_complete", "task_complete"):
                print(pre + c(self.color, BOLD + "■ turn complete") + RST)
            elif pt == "web_search_begin":
                print(pre + c(34, "🔎 ") + trunc(p.get("query", ""), 160))
            return
        if t == "response_item":
            pt = p.get("type")
            if pt == "reasoning":
                texts = [s.get("text", "") for s in (p.get("summary") or []) if isinstance(s, dict)]
                txt = " ".join(x for x in texts if x)
                if txt:
                    print(pre + DIM + "🧠 " + trunc(txt, 280) + RST)
            elif pt in ("custom_tool_call", "function_call"):
                name = p.get("name", "?")
                arg = p.get("input") or p.get("arguments") or ""
                print(pre + c(33, f"⚙ {name} ") + DIM + trunc(arg, 160) + RST)

def find(since_min):
    cut = time.time() - since_min * 60
    return sorted(
        (f for f in glob.glob(os.path.join(SESS, "*", "*", "*", "rollout-*.jsonl"))
         if os.path.getmtime(f) > cut),
        key=os.path.getmtime,
    )

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--since", type=float, default=15, help="attach window in minutes")
    ap.add_argument("--last", action="store_true", help="replay newest session fully")
    ap.add_argument("--for", dest="dur", type=float, default=0, help="exit after N seconds")
    ap.add_argument("--no-tokens", action="store_true")
    a = ap.parse_args()

    tails = {}
    if a.last:
        allf = find(60 * 24 * 7)
        files = allf[-1:] if allf else []
        if not files:
            print("no sessions found"); return
    else:
        files = find(a.since)

    for f in files:
        tails[f] = Tail(f, replay_all=a.last)

    n = len(tails)
    print(DIM + f"gpt-watch: following {n} session(s); auto-discovering new workers. Ctrl-C to exit." + RST)

    t0, last_scan = time.time(), 0.0
    try:
        while True:
            if not a.last and time.time() - last_scan > 2:
                last_scan = time.time()
                for f in find(a.since):
                    if f not in tails:
                        tails[f] = Tail(f, replay_all=True)
            idle = True
            for tl in tails.values():
                while True:
                    line = tl.fh.readline()
                    if not line:
                        break
                    idle = False
                    tl.emit(line, show_tokens=not a.no_tokens)
            if a.dur and time.time() - t0 > a.dur:
                return
            if idle:
                time.sleep(0.4)
    except KeyboardInterrupt:
        pass

if __name__ == "__main__":
    main()
