#!/usr/bin/env python3
"""gpt-fleet — deterministic DAG orchestrator for GPT-5.6 workers (gpt-run under the hood).

The Workflow-tool equivalent for the gpt-architect skill: Claude writes ONE spec, launches
this as ONE background Bash task, and the whole pipeline runs itself — independent workers
in parallel, dependent stages fired the moment their deps finish, zero Claude tokens spent
between hops. One notification at the end; the task output contains every worker's
🤖 summary + FINAL MESSAGE.

Usage:  gpt-fleet <spec.json>

Spec:
{
  "name": "release-review",
  "cwd": "/abs/default/cwd",
  "max_parallel": 4,                              // optional, default 4
  "workers": [
    {"name": "audit",  "model": "sol",  "effort": "high",   "sandbox": "ro",
     "prompt": "OBJECTIVE: ... FINAL MESSAGE FORMAT: <=15 lines"},
    {"name": "fix",    "model": "terra","effort": "high",   "sandbox": "ws",
     "after": ["audit"],
     "prompt": "The auditor reported:\n{{final:audit}}\nFix items 1-3. ..."}
  ]
}
{{final:NAME}} in a prompt is replaced by that worker's FINAL MESSAGE.
Workers whose dependency failed are skipped (marked ⤼). Exit 0 iff all ok.
Artifacts: each worker in ~/.claude/gpt-runs/<ts>-<name>/ (via gpt-run) +
fleet prompts in ~/.claude/gpt-runs/fleet-<ts>-<specname>/.
"""
import json, os, queue, re, shutil, subprocess, sys, threading, time

BIN_DIR = os.path.dirname(os.path.abspath(__file__))
GPT_RUN = os.environ.get("GPT_RUN", os.path.join(BIN_DIR, "gpt-run"))
GPT_QUOTA = os.environ.get("GPT_QUOTA", os.path.join(BIN_DIR, "gpt-quota"))


def main():
    if len(sys.argv) != 2:
        sys.exit(__doc__)
    spec = json.load(open(sys.argv[1]))
    workers = {}
    for w in spec["workers"]:
        if w["name"] in workers:
            sys.exit(f"duplicate worker name: {w['name']}")
        workers[w["name"]] = w
    for w in workers.values():
        for d in w.get("after", []):
            if d not in workers:
                sys.exit(f"unknown dependency '{d}' for worker '{w['name']}'")

    maxp = spec.get("max_parallel", 4)
    if not isinstance(maxp, int) or isinstance(maxp, bool) or maxp < 1:
        sys.exit("max_parallel must be a positive integer")
    if maxp > 4:
        print(f"max_parallel={maxp} exceeds the hard cap of 4; clamping to 4", file=sys.stderr)
        maxp = 4
    default_cwd = spec.get("cwd", os.getcwd())
    fname = spec.get("name", "fleet")
    fleet_dir = os.path.expanduser(
        f"~/.claude/gpt-runs/fleet-{time.strftime('%Y%m%d-%H%M%S')}-{fname}")
    os.makedirs(fleet_dir, exist_ok=True)

    status = {n: "pending" for n in workers}          # pending|running|ok|fail|skip
    finals, done_q = {}, queue.Queue()
    total, completed, running = len(workers), 0, 0
    t0 = time.time()
    print(f"⛴ fleet '{fname}' · {total} workers · max_parallel={maxp} · {fleet_dir}",
          flush=True)

    def elapsed():
        return f"{round((time.time() - t0) / 60, 1)}m"

    def launch(n):
        w = workers[n]
        prompt = w["prompt"]
        for dep in w.get("after", []):
            prompt = prompt.replace("{{final:%s}}" % dep, finals.get(dep, "(no report)"))
        pf = os.path.join(fleet_dir, n + ".prompt.md")
        open(pf, "w").write(prompt)
        cmd = [GPT_RUN, "-m", w.get("model", "terra"), "-e", w.get("effort", "high"),
               "-s", w.get("sandbox", "ws"), "-C", w.get("cwd", default_cwd), "-n", n, pf]

        def run():
            p = subprocess.run(cmd, capture_output=True, text=True,
                               stdin=subprocess.DEVNULL)
            done_q.put((n, p.returncode, p.stdout + p.stderr))

        print(f"▶ {n} ({w.get('model','terra')} {w.get('effort','high')} "
              f"{w.get('sandbox','ws')}) started · {elapsed()}", flush=True)
        threading.Thread(target=run, daemon=True).start()

    while completed < total:
        progressed = True
        while progressed:
            progressed = False
            for n, w in workers.items():
                if status[n] == "pending" and any(
                        status[d] in ("fail", "skip") for d in w.get("after", [])):
                    status[n] = "skip"
                    completed += 1
                    progressed = True
                    print(f"⤼ {n} skipped (dependency failed) [{completed}/{total}]",
                          flush=True)
            for n, w in workers.items():
                if running >= maxp:
                    break
                if status[n] == "pending" and all(
                        status[d] == "ok" for d in w.get("after", [])):
                    status[n] = "running"
                    launch(n)
                    running += 1
                    progressed = True
        if completed >= total:
            break
        if running == 0:
            print("✖ fleet stuck — circular dependencies?", flush=True)
            break
        n, rc, out = done_q.get()
        running -= 1
        completed += 1
        status[n] = "ok" if rc == 0 else "fail"
        m = re.search(r"^--- FINAL MESSAGE.*?---$", out, re.M)
        finals[n] = out[m.end():].strip() if m else ""
        icon = "✔" if rc == 0 else "✖"
        print(f"\n{icon} {n} [{completed}/{total}] · {elapsed()} elapsed", flush=True)
        print("\n".join("  │ " + l for l in out.strip().splitlines()), flush=True)

    ok = sum(1 for s in status.values() if s == "ok")
    print(f"\n═══ FLEET '{fname}' DONE · {ok}/{total} ok · {elapsed()} ═══")
    icons = {'ok': '✔', 'fail': '✖', 'skip': '⤼', 'pending': '?', 'running': '?'}
    for n, s in status.items():
        print(f"  {icons[s]} {n}")
    try:
        q = subprocess.run([GPT_QUOTA, "-s"],
                           capture_output=True, text=True, timeout=10).stdout.strip()
        if q:
            print("  quota: " + q)
    except Exception:
        pass
    try:
        osascript = shutil.which("osascript")
        if osascript:
            subprocess.run([osascript, "-e",
                            f'display notification "{fname}: {ok}/{total} ok" '
                            f'with title "GPT fleet finished" sound name "Glass"'],
                           timeout=10)
    except Exception:
        pass
    sys.exit(0 if ok == total else 1)


if __name__ == "__main__":
    main()
