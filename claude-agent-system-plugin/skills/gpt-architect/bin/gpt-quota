#!/usr/bin/env python3
"""gpt-quota — current ChatGPT subscription quota, from the newest Codex rollout.

Usage: gpt-quota        human line: 5h 31% (resets 3h23m) · week 5% (resets 6d2h) · plan prolite
       gpt-quota -s     short:      5h 31% · wk 5%
Exit 1 if no recent data (no session in the last 24h)."""

import glob, json, os, re, sys, time

files = sorted(
    glob.glob(os.path.expanduser("~/.codex/sessions/*/*/*/rollout-*.jsonl")),
    key=os.path.getmtime,
)
now = time.time()
rl = None
src = age = None
for f in reversed(files):
    if now - os.path.getmtime(f) > 86400:
        break
    # rate_limits ride on token_count events; scan the tail of the file backwards
    with open(f, "rb") as fh:
        fh.seek(max(0, os.path.getsize(f) - 262_144))
        tail = fh.read().decode("utf8", "ignore")
    hits = re.findall(r'"rate_limits":(\{.*?"secondary":\{.*?\}.*?\})[,}]', tail)
    for h in reversed(hits):
        try:
            cand = json.loads(h + ("}" if h.count("{") > h.count("}") else ""))
        except Exception:
            continue
        if cand.get("primary"):
            rl = cand
            src = os.path.basename(f)[-12:-6]
            age = now - os.path.getmtime(f)
            break
    if rl:
        break

if not rl:
    print("no quota data (no Codex session in last 24h)")
    sys.exit(1)

def left(w):
    s = (w or {}).get("resets_at")
    if not s:
        return ""
    s = int(s - now)
    if s <= 0:
        return " (resetting)"
    d, h, m = s // 86400, s % 86400 // 3600, s % 3600 // 60
    return " (resets " + (f"{d}d{h}h" if d else f"{h}h{m}m" if h else f"{m}m") + ")"

p, w = rl.get("primary") or {}, rl.get("secondary") or {}
if "-s" in sys.argv:
    print(f"5h {p.get('used_percent',0):.0f}% · wk {w.get('used_percent',0):.0f}%")
else:
    ago = f"{int(age//60)}m" if age >= 60 else f"{int(age)}s"
    print(
        f"GPT quota: 5h {p.get('used_percent',0):.0f}%{left(p)}"
        f" · week {w.get('used_percent',0):.0f}%{left(w)}"
        f" · plan {rl.get('plan_type','?')} · as of {ago} ago (…{src})"
    )
