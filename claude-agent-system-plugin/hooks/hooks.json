{
  "description": "Resume open CAS handoffs, enforce GPT Architect's session-local backend (native-teammate denial, inline-write cap, per-prompt standing orders), protect secrets, and require approval for rm, git commit, and git push",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/orchestrate-resume.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/gpt-architect-standing-orders.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/protect-secrets.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/sensitive-command-approval.cjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^(Agent|Task|Workflow|Edit|MultiEdit|Write|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/gpt-architect-mode-guard.cjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
