{
  "name": "spectra-mcp-server",
  "version": "0.1.0",
  "description": "Lightning-fast headless browser MCP server for E2E frontend testing. See everything. Touch everything. Faster than sight.",
  "type": "module",
  "bin": {
    "spectra": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "browser",
    "e2e",
    "testing",
    "headless",
    "cdp",
    "chrome-devtools-protocol",
    "claude-code"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chrome-launcher": "^1.1.2",
    "chrome-remote-interface": "^0.33.2",
    "fast-diff": "^1.3.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.31.14",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
